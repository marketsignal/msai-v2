# Claude Code (per-developer state — Forge convention: only .claude/local/ + transient artifacts gitignored, NOT the whole .claude/ tree)
.claude/local/
.claude/settings.bak.*
.claude/scheduled_tasks.lock
.claude/settings.local.json
.playwright-mcp/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl
.venv/
venv/
.uv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage

# Node
node_modules/
.pnpm-store/
.next/
out/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Data files (large, generated)
*.parquet
data/parquet/
data/reports/
data/alerts/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Environment
.env
.env.local
.env.*.local
.env.*-backup*
.env.*-snapshot*
.env.live-snapshot-*
docker-compose.override.yml

# IB Gateway credentials
scripts/ib-gateway-config/*.ini
.worktrees/
.ibaccounts.txt

# Docker runtime state (IB Gateway logs/jars/configs, Nautilus cache, scheduler, ingestion status)
data/ib-gateway/
data/nautilus/
data/scheduler/
data/ingestion_status.json

# Logs / Jupyter (from pre-flatten claude-version/.gitignore)
*.log
logs/
.ipynb_checkpoints/

# OS / Windows (from pre-flatten claude-version/.gitignore)
Thumbs.db
ehthumbs.db
Desktop.ini

# Secrets
*.pem
*.key
data/databento_definitions/

# Superpowers brainstorming visual companion (per-session mockups)
.superpowers/
