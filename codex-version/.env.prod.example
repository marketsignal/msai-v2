POSTGRES_DB=msai
POSTGRES_USER=msai
POSTGRES_PASSWORD=replace-with-strong-password

DATABASE_URL=postgresql+asyncpg://msai:replace-with-strong-password@postgres:5432/msai
REDIS_URL=redis://redis:6379/0
DATA_ROOT=/app/data
STRATEGIES_ROOT=/app/strategies
ENVIRONMENT=production

JWT_TENANT_ID=replace-with-entra-tenant-id
JWT_CLIENT_ID=replace-with-entra-client-id
MSAI_API_KEY=replace-with-operator-api-key

NEXT_PUBLIC_API_URL=https://msai.example.com
NEXT_PUBLIC_ENTRA_CLIENT_ID=replace-with-entra-client-id
NEXT_PUBLIC_ENTRA_TENANT_ID=replace-with-entra-tenant-id
NEXT_PUBLIC_ENTRA_REDIRECT_URI=https://msai.example.com/auth/callback

DATABENTO_API_KEY=replace-with-databento-key
DAILY_INGEST_ENABLED=true
DAILY_INGEST_TIMEZONE=America/Chicago
DAILY_INGEST_HOUR=18
DAILY_INGEST_MINUTE=30
DAILY_INGEST_POLL_SECONDS=60

TWS_USERID=replace-with-ib-paper-username
TWS_PASSWORD=replace-with-ib-paper-password
TRADING_MODE=paper
READ_ONLY_API=no
IB_TWS_SETTINGS_PATH=/home/ibgateway/tws_settings
IB_AUTO_RESTART_TIME=11:45 PM
IB_TWS_COLD_RESTART=
IB_RELOGIN_AFTER_TWOFA_TIMEOUT=yes
IB_TWOFA_TIMEOUT_ACTION=restart
IB_EXISTING_SESSION_ACTION=primary
IB_TWS_ACCEPT_INCOMING=accept
IB_BYPASS_WARNING=yes
IB_TIME_ZONE=America/Chicago
IB_JAVA_HEAP_SIZE=1024
VNC_SERVER_PASSWORD=replace-with-vnc-password
IB_ACCOUNT_ID=replace-with-ib-account-id
IB_ALLOW_MOCK_FALLBACK=false
