# MSAI v2 (Claude Version) — Environment Variables Template
#
# Copy this file to `.env` in the same directory and fill in real values.
# `.env` is gitignored; `.env.example` is committed so new contributors
# know which variables exist.
#
# Quick start for live paper trading:
#   1. cp .env.example .env
#   2. Fill in TWS_USERID, TWS_PASSWORD, IB_ACCOUNT_ID (paper account)
#   3. docker compose -f docker-compose.dev.yml up -d
#
# The `COMPOSE_PROFILES=live` line below activates the ib-gateway +
# live-supervisor services automatically on `docker compose up`. Comment
# it out if you only want the backend/frontend/database stack without
# live trading (e.g., frontend-only development).

# ---------------------------------------------------------------------------
# Compose profile activation — set to "live" to start ib-gateway + supervisor
# ---------------------------------------------------------------------------
COMPOSE_PROFILES=live

# ---------------------------------------------------------------------------
# Interactive Brokers — paper trading account
# ---------------------------------------------------------------------------
# TWS_USERID / TWS_PASSWORD are your IB login credentials. For paper
# trading, create a dedicated paper account from your live IB account
# at https://www.interactivebrokers.com/sso/Login → "Paper Trading
# Account". IBC (the automation layer inside the ib-gateway container)
# logs in automatically with these credentials on container startup.
#
# IB_ACCOUNT_ID is the account number IB assigns to your paper account.
# It MUST start with `DU` or `DF` (FA sub-accounts use `DFP` prefix).
# The port/account consistency check in
# `live_node_config.py::_validate_port_account_consistency` rejects
# paper ports paired with live account ids (and vice versa) as a silent
# data-flow killer guard (gotcha #6).
#
# DO NOT commit these to git. .env is in .gitignore for exactly this
# reason.
TWS_USERID=your_ib_username
TWS_PASSWORD=your_ib_password
IB_ACCOUNT_ID=DU0000000

# Trading mode: `paper` (default) or `live`. Keep this set to `paper`
# for the 30-day paper soak. Flipping to `live` requires the full
# release sign-off checklist (`docs/release-signoff-checklist.md`).
TRADING_MODE=paper

# Read-only API flag. Set to `no` to allow order submission (required
# for paper soak). Set to `yes` to force the gateway into read-only
# mode — market data + account queries work, but every order submission
# is rejected by IB Gateway before it reaches the broker. Useful for
# "safe" dev runs where you want to verify the stack without risking
# fat-finger order submissions.
READ_ONLY_API=no

# IB market data type. Determines what kind of market data the
# TradingNode requests. Options:
#   REALTIME       — requires a market data subscription (paid or free bundle)
#   DELAYED        — 15-minute delayed data (free for most instruments)
#   DELAYED_FROZEN — last available delayed snapshot
#
# If your paper account gets IB code 420 ("no market data permissions"),
# either subscribe to "US Securities Snapshot and Futures Value Bundle"
# (free for paper accounts linked to a funded live account) in IB Account
# Management → Settings → Market Data Subscriptions, or set this to DELAYED.
IB_MARKET_DATA_TYPE=REALTIME

# ---------------------------------------------------------------------------
# Postgres (production only — dev has a default password)
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=change_me_for_prod

# ---------------------------------------------------------------------------
# API keys (optional — only needed for market data ingestion)
# ---------------------------------------------------------------------------
POLYGON_API_KEY=
DATABENTO_API_KEY=

# ---------------------------------------------------------------------------
# Auth (optional in dev — required in prod)
# ---------------------------------------------------------------------------
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
MSAI_API_KEY=msai-dev-key

# ---------------------------------------------------------------------------
# Backtest report signed-URL machinery
# ---------------------------------------------------------------------------
# HMAC secret for signed /api/v1/backtests/{id}/report URLs. The backend
# mints a short-lived token scoped to (backtest_id, user_sub, expires_at)
# so the iframe can load the report without a server-side API key in the
# Next.js container. Rotate on every production deploy — a token signed
# under an old secret stops validating immediately.
# Must be a cryptographically random string (openssl rand -base64 48 is fine).
REPORT_SIGNING_SECRET=dev-report-signing-secret-change-in-prod
